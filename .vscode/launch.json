{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (Windows Forms)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/bin/Debug/net8.0-windows/win-x64/APmodManager.exe",
            "args": [],
            "cwd": "${workspaceFolder}/src/bin/Debug/net8.0-windows/win-x64",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
